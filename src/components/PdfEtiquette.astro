---
import { randomUUID } from 'node:crypto';
const { page, x, y, w, h, pdfUrl = '/pdf/guide-survie-c3.pdf', etiquetteUrl = '#' } = Astro.props;
const uid = randomUUID().slice(0, 8);
---

<div
  class="pdf-wrap"
  id={`pw-${uid}`}
  style={`aspect-ratio: ${w} / ${h};`}
  data-pdf={pdfUrl}
  data-page={page}
  data-x={x}
  data-y={y}
  data-w={w}
  data-h={h}
  data-lightbox={`lb-${uid}`}
>
  <canvas class="pdf-canvas"></canvas>
  <div class="pdf-loading">Chargement…</div>
  <a class="isolate-btn" href={etiquetteUrl} title="Voir la fiche">⤢</a>
</div>

<div class="pdf-lightbox" id={`lb-${uid}`}>
  <div class="lightbox-backdrop" data-close></div>
  <div class="lightbox-inner">
    <canvas class="lb-canvas"></canvas>
    <button class="lb-close" data-close>✕</button>
  </div>
</div>

<style>
.pdf-wrap {
  position: relative;
  width: 100%;
  overflow: hidden;
  background: #f1f5f9;
  cursor: zoom-in;
  border-radius: inherit;
}

.pdf-canvas { width: 100%; height: 100%; display: block; }

.pdf-loading {
  position: absolute; inset: 0;
  display: flex; align-items: center; justify-content: center;
  font-size: 0.75rem; color: #94a3b8; pointer-events: none;
}
.pdf-loading.hidden { display: none; }

.isolate-btn {
  position: absolute; top: 6px; right: 6px;
  width: 28px; height: 28px; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  opacity: 0; transition: opacity 0.2s;
  background: rgba(15,23,42,0.7); color: white;
  border: none; cursor: pointer; text-decoration: none;
  font-size: 0.9rem; z-index: 10;
}
.pdf-wrap:hover .isolate-btn { opacity: 1; }

/* Lightbox */
.pdf-lightbox {
  display: none; position: fixed; inset: 0; z-index: 9999;
  align-items: center; justify-content: center;
}
.pdf-lightbox.open { display: flex; }

.lightbox-backdrop {
  position: absolute; inset: 0;
  background: rgba(0,0,0,0.8); backdrop-filter: blur(4px);
  cursor: zoom-out;
}
.lightbox-inner {
  position: relative; z-index: 1;
  max-width: min(95vw, 1100px); max-height: 92vh;
  overflow: auto; border-radius: 8px;
  box-shadow: 0 30px 80px rgba(0,0,0,0.6);
}
.lb-canvas { display: block; max-width: 100%; height: auto; border-radius: 8px; }
.lb-close {
  position: sticky; top: 8px; float: right; margin: 8px 8px 0 0;
  width: 32px; height: 32px; border-radius: 50%;
  background: rgba(0,0,0,0.65); color: white;
  border: none; font-size: 1rem; cursor: pointer;
  display: flex; align-items: center; justify-content: center; z-index: 2;
}
</style>
