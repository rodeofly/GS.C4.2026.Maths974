---
// src/components/Etiquette.astro
import QRCode from './QRCode.astro';
import Accordion from './Accordion.astro';
import PdfEtiquette from './PdfEtiquette.astro';

const { entry } = Astro.props;
const { data: fm } = entry;

const { Content } = await entry.render();

const formatRaw = String(fm.format ?? '1').replace('/', '_').replace('.', '_');
const formatClass = `format-${formatRaw}`;
const fullWidthClass = fm.full_width ? 'etiquette-full-width' : '';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const cleanSlug = entry.slug.replace(/\/index$/, '');
const etiquetteUrl = `${base}/guide/${cleanSlug}/`;

const liens = Array.isArray(fm.liens) ? fm.liens : [];
const useBlocs = Array.isArray(fm.blocs) && fm.blocs.length > 0;
const usePdf   = !!fm.pdf;

// Markdown inline → HTML  (ne touche pas au LaTeX $...$)
function parseInline(text: string): string {
  if (!text) return '';
  return text
    .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
    .replace(/\*(.+?)\*/g, '<em>$1</em>');
}

// Retours à la ligne + markdown inline
function nl2br(text: string): string {
  return parseInline(text.trim()).replace(/\n/g, '<br/>');
}

---

<article class={`etiquette ${formatClass} ${fullWidthClass} ${usePdf ? 'etiquette--pdf' : ''}`} id={fm.id}>

  {/* En mode PDF : pas de header redondant */}
  {!usePdf && <header class="etiquette-header">
    <div class="header-top">
      <h2 class="etiquette-title">
        <a href={etiquetteUrl} class="title-link">{fm.title ?? 'Étiquette'}</a>
      </h2>
      <a href={etiquetteUrl} class="isolate-btn no-print" title="Isoler cette fiche" aria-label="Vue détaillée">⤢</a>
    </div>
    <div class="etiquette-meta">
      {fm.id && <span class="etiquette-id">{fm.id}</span>}
    </div>
  </header>}  {/* fin !usePdf header */}

  {/* ── MODE PDF ── */}
  {usePdf && (
    <PdfEtiquette
      page={fm.pdf!.page}
      x={fm.pdf!.x}
      y={fm.pdf!.y}
      w={fm.pdf!.w}
      h={fm.pdf!.h}
      etiquetteUrl={etiquetteUrl}
    />
  )}

  {/* ── SYSTÈME BLOCS ── */}
  {useBlocs && fm.blocs!.map(bloc => (
    <>
      {bloc.type === 'enonce' && (
        <div class="etiquette-enonce" set:html={parseInline(bloc.contenu)} />
      )}

      {bloc.type === 'redaction' && (
        <section class="etiquette-section section-texte">
          <div set:html={nl2br(bloc.contenu)} />
        </section>
      )}

      {bloc.type === 'illustration' && (
        <figure class="etiquette-illustration">
          <img src={bloc.url} alt={bloc.alt ?? ''} loading="lazy" />
        </figure>
      )}

      {bloc.type === 'retenir' && (
        <section class="etiquette-section section-retain">
          <ul class="contenus">
            {bloc.items.map(item => (
              <li set:html={parseInline(item)} />
            ))}
          </ul>
        </section>
      )}

      {bloc.type === 'erreur' && (
        <section class="etiquette-section section-erreurs">
          <h3 class="section-erreurs-title">Erreurs à éviter</h3>
          <ul>
            {bloc.items.map(err => (
              <li set:html={parseInline(err)} />
            ))}
          </ul>
        </section>
      )}

      {bloc.type === 'rappel' && (
        <div class="section-rappel etiquette-section">
          <p set:html={nl2br(bloc.contenu)} />
        </div>
      )}

      {bloc.type === 'accordeon' && (
        <div class="accordion-container no-print">
          <Accordion titre={bloc.titre} contenu={bloc.contenu} />
        </div>
      )}

      {bloc.type === 'tableau' && (
        <div class="etiquette-tableau">
          <table>
            <thead>
              <tr>
                {bloc.entetes.map(h => <th set:html={parseInline(h)} />)}
              </tr>
            </thead>
            <tbody>
              {bloc.lignes.map(ligne => (
                <tr>
                  {ligne.map(cell => <td set:html={parseInline(cell)} />)}
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}
    </>
  ))}

  {/* ── FOOTER LIENS / QR ── */}
  {liens.length > 0 && (
    <footer class="etiquette-footer">
      <div class="qr-collection">
        {liens.map(lien => <QRCode lien={lien} />)}
      </div>
    </footer>
  )}

</article>

<style>
  .header-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
  }

  .title-link {
    text-decoration: none;
    color: inherit;
    background-image: linear-gradient(transparent 90%, var(--color-guide-primary) 90%);
    background-size: 0% 100%;
    background-repeat: no-repeat;
    transition: background-size 0.3s ease, color 0.3s ease;
  }

  .title-link:hover {
    color: var(--color-guide-primary);
    background-size: 100% 100%;
  }

  .isolate-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background-color: var(--color-gray-100);
    color: var(--color-gray-600);
    text-decoration: none;
    font-size: 1.2rem;
    line-height: 1;
    transition: all 0.2s ease;
    flex-shrink: 0;
    opacity: 0.6;
  }

  .etiquette:hover .isolate-btn { opacity: 1; }
  .isolate-btn:hover { background-color: var(--color-guide-primary); color: white; transform: scale(1.1); }

  .etiquette-id {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: bold;
    color: white;
    background: var(--color-guide-primary);
    padding: 2px 8px;
    border-radius: 12px;
    margin-top: 0.5rem;
  }

  /* Tableau */
  .etiquette-tableau {
    overflow-x: auto;
  }

  .etiquette-tableau table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--text-sm);
  }

  .etiquette-tableau th,
  .etiquette-tableau td {
    border: 1px solid var(--color-gray-200);
    padding: var(--space-2) var(--space-3);
    text-align: center;
  }

  .etiquette-tableau th {
    background: var(--color-guide-bg);
    font-weight: var(--font-bold);
    color: var(--color-guide-primary);
  }

  .etiquette-tableau td:first-child {
    font-weight: var(--font-semibold);
    text-align: left;
    background: var(--color-gray-50);
  }
</style>
