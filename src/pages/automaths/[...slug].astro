---
// src/pages/automaths/[...slug].astro
import { getCollection } from 'astro:content';
import AutomathsLayout from '../../layouts/AutomathsLayout.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

export async function getStaticPaths() {
  const entries = await getCollection('automaths');
  return entries.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { slug } = Astro.params;

const parts = slug ? slug.split('/') : [];
const parentSlug = parts.slice(0, -1).join('/');
const parentUrl = parentSlug ? `${base}/automaths/${parentSlug}/` : `${base}/automaths/`;
---

<AutomathsLayout info={entry} parentUrl={parentUrl} />
