---
import '../styles/main.css';
import '../styles/components/rapidos-visuals.css';
import { getCollection } from 'astro:content';

const { info, parentUrl = ".." } = Astro.props;
const data = info.data || {};

const numero = data.numero || "1";
const niveau = data.niveau || "";
const questions = Array.isArray(data.questions) ? data.questions : [];

const pageTitle = `Rapido ${numero} - ${niveau}`;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const gsIdsUsed = new Set<string>();
for (const q of questions) {
  if (q.gs) gsIdsUsed.add(q.gs);
  for (const v of q.variantes ?? []) {
    if (v.gs) gsIdsUsed.add(v.gs);
  }
}

const guideFiches = await getCollection('guide');
const gsPdfData: Record<string, { title: string; page: number; x: number; y: number; w: number; h: number }> = {};
for (const fiche of guideFiches) {
  if (!fiche.data.id || !fiche.data.pdf) continue;
  const key = `GS ${fiche.data.id}`;
  if (gsIdsUsed.has(key)) {
    gsPdfData[key] = { title: fiche.data.title ?? key, ...fiche.data.pdf };
  }
}
---

<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <link rel="stylesheet" type="text/css" href="https://tikzjax.com/v1/fonts.css" />
    <script is:inline>
        window.MathJax = { tex: { inlineMath: [['$', '$'], ['\\(', '\\)']] }, svg: { fontCache: 'global' } };
    </script>
    <script src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-svg-full.js" defer></script>

    <style>
       .rapido-body {
          margin: 0;
          height: 100vh; width: 100vw;
          overflow: hidden;
          font-family: var(--font-sans) !important;
          color: #1e293b;
          background: linear-gradient(to bottom, #dc2626, #fca5a5);
          position: relative;
       }
       h1, h2, button { font-family: var(--font-sans) !important; }
       .bg-curves { position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover; z-index: 1; opacity: 0.6; pointer-events: none; }
       .back-btn { position: absolute; top: 1rem; left: 1rem; background: rgba(255,255,255,0.2); color: white; border-radius: 50%; text-decoration: none; font-weight: bold; z-index: 50; backdrop-filter: blur(4px); transition: background 0.2s; display: flex; align-items: center; justify-content: center; width: 44px; height: 44px; padding: 0; font-size: 1.5rem; border: 2px solid rgba(255,255,255,0.4); }
       .back-btn:hover { background: rgba(255,255,255,0.4); }
       .rapido-container { position: relative; z-index: 10; height: 100%; padding: 0.25rem 4rem 0.5rem 4rem; display: flex; flex-direction: column; }
       header { text-align: center; margin-bottom: 0.25rem; display: flex; flex-direction: column; align-items: center; position: relative; }
       .deco-area { width: 100%; position: relative; margin-top: 0.25rem; display: flex; align-items: flex-end; }
       .deco-volcan-wrapper { position: absolute; right: 0; bottom: 2.5rem; display: flex; flex-direction: column; align-items: center; z-index: 5; pointer-events: none; }
       .deco-volcan { width: 150px; max-width: 18vw; height: auto; filter: drop-shadow(0 4px 6px rgba(0,0,0,0.3)); }
       .copyright { color: white; font-size: 0.85rem; font-weight: 800; margin-top: -16px; text-shadow: 0 2px 4px rgba(0,0,0,0.8); font-family: var(--font-sans); letter-spacing: 0.05em; position: relative; z-index: 6; }
       .frise-lambrequin { height: 2.5rem; width: 100%; background-repeat: repeat-x; background-size: contain; background-position: top center; position: relative; z-index: 10; }
       .title-wrapper { display: flex; align-items: center; justify-content: center; gap: 1rem; margin-top: 0.25rem; }
       h1 { color: white; font-size: 2.2rem; margin: 0; text-transform: uppercase; font-weight: 900; letter-spacing: 0.02em; text-shadow: 0 4px 10px rgba(0,0,0,0.2); line-height: 1; }
       .rapido-badge { background-color: #fbbf24; color: #0f172a; font-family: var(--font-sans); font-weight: 900; font-size: 1.1rem; width: 2.4rem; height: 2.4rem; border-radius: 50%; display: flex; align-items: center; justify-content: center; transform: rotate(-10deg); box-shadow: 0 6px 12px rgba(0,0,0,0.3); border: 2px solid white; z-index: 10; }
       .deco-margouillat { position: absolute; top: 0; right: 22%; width: 6vw; max-width: 120px; z-index: 2; pointer-events: none; filter: drop-shadow(0 4px 6px rgba(0,0,0,0.3)); transform: rotate(15deg); }
       .questions-grid { display: grid; grid-template-columns: 1fr 1fr; grid-template-rows: repeat(3, 1fr); gap: 1rem; flex: 1; min-height: 0; }
       .rapido-pagination { display: none; align-items: center; justify-content: center; gap: 0.75rem; padding: 0.4rem 0; flex-shrink: 0; }
       .pag-btn { background: rgba(255,255,255,0.25); color: white; border: 2px solid rgba(255,255,255,0.5); border-radius: 50%; width: 2.2rem; height: 2.2rem; font-size: 1.3rem; font-weight: 900; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: background 0.15s; line-height: 1; }
       .pag-btn:hover:not(:disabled) { background: rgba(255,255,255,0.45); }
       .pag-btn:disabled { opacity: 0.3; cursor: default; }
       .pag-info { color: white; font-weight: 800; font-size: 1rem; letter-spacing: 0.05em; text-shadow: 0 2px 4px rgba(0,0,0,0.2); min-width: 3rem; text-align: center; }
       .rapido-breadcrumb { position: absolute; top: 1rem; left: 5rem; z-index: 50; display: flex; align-items: center; gap: 0.4rem; font-size: 0.8rem; color: rgba(255,255,255,0.8); font-weight: 500; }
       .rapido-breadcrumb a { color: white; text-decoration: none; opacity: 0.75; transition: opacity 0.2s; display: flex; align-items: center; }
       .rapido-breadcrumb a:hover { opacity: 1; }
       .rapido-breadcrumb .sep { opacity: 0.45; font-size: 0.7rem; }
       .rapido-breadcrumb .curr { font-weight: 800; color: white; opacity: 1; }
       /* Overlay Guide de Survie */
       .gs-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.65); z-index: 2000; align-items: center; justify-content: center; backdrop-filter: blur(4px); }
       .gs-overlay.open { display: flex; }
       .gs-overlay-inner { background: white; border-radius: 1.5rem; padding: 1.5rem 1.5rem 1rem; width: 88vw; max-width: 88vw; max-height: 90vh; overflow: auto; box-shadow: 0 25px 60px rgba(0,0,0,0.45); position: relative; min-width: 260px; }
       .gs-overlay-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1rem; gap: 1rem; }
       .gs-overlay-title { font-size: 0.95rem; font-weight: 800; color: #0f766e; text-transform: uppercase; letter-spacing: 0.05em; }
       .gs-overlay-close { background: #f1f5f9; border: none; border-radius: 50%; width: 2rem; height: 2rem; font-size: 1rem; cursor: pointer; display: flex; align-items: center; justify-content: center; color: #475569; transition: background 0.15s; flex-shrink: 0; }
       .gs-overlay-close:hover { background: #e2e8f0; }
       .gs-overlay-canvas-wrap { position: relative; }
       .gs-overlay-canvas { display: block; max-width: 100%; height: auto; }
       .gs-overlay-loading { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; color: #64748b; font-size: 0.875rem; }
       .gs-overlay-loading.hidden { display: none; }
    </style>
</head>

<body class="rapido-body">

  <img src={`${base}/images/curves.svg`} alt="" class="bg-curves" />
  <img src={`${base}/images/margouillat.png`} alt="Margouillat" class="deco-margouillat" />

  <a href={parentUrl} class="back-btn" aria-label="Retour au menu">⬅</a>
  <nav class="rapido-breadcrumb">
    <a href={`${base}/`} aria-label="Accueil">
      <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
        <polyline points="9 22 9 12 15 12 15 22"/>
      </svg>
    </a>
    <span class="sep">/</span>
    <a href={`${base}/rapidos/`}>Rapidos</a>
    {niveau && (
      <>
        <span class="sep">/</span>
        <span class="curr">{niveau}</span>
      </>
    )}
  </nav>

  <div class="rapido-container">
    <header>
      <div class="title-wrapper">
        <h1>Rapido {niveau}</h1>
        <div class="rapido-badge">{numero}</div>
      </div>
      <div class="deco-area">
        <div class="deco-volcan-wrapper">
          <img src={`${base}/images/volcan.svg`} alt="Volcan" class="deco-volcan" />
          <div class="copyright">© maths974</div>
        </div>
        <div class="frise-lambrequin" style={`background-image: url('${base}/images/lambrequin.svg');`}></div>
      </div>
    </header>

    <div class="questions-grid" id="questions-grid"></div>

    <div class="rapido-pagination" id="rapido-pagination">
      <button class="pag-btn" id="rapido-prev" disabled aria-label="Page précédente">‹</button>
      <span class="pag-info" id="rapido-page-info"></span>
      <button class="pag-btn" id="rapido-next" aria-label="Page suivante">›</button>
    </div>
  </div>

  <!-- Overlay Guide de Survie -->
  <div id="gs-overlay" class="gs-overlay" role="dialog" aria-modal="true" aria-hidden="true">
    <div class="gs-overlay-inner">
      <div class="gs-overlay-header">
        <div class="gs-overlay-title" id="gs-overlay-title"></div>
        <button class="gs-overlay-close" data-close aria-label="Fermer">✕</button>
      </div>
      <div class="gs-overlay-canvas-wrap">
        <canvas class="gs-overlay-canvas" id="gs-overlay-canvas"></canvas>
        <div class="gs-overlay-loading" id="gs-overlay-loading">Chargement…</div>
      </div>
    </div>
  </div>

  <script is:inline define:vars={{ questions, niveau, numero, gsPdfData, base }}>
    window.__RAPIDO_QUESTIONS__ = questions;
    window.__GS_PDF_DATA__      = gsPdfData;
    window.__BASE_URL__         = base;
    window.__RAPIDO_NIVEAU__    = niveau;
    window.__RAPIDO_NUMERO__    = numero;
  </script>

  <script>
    import * as pdfjsLib from 'pdfjs-dist';
    import { initEngine } from '../utils/rapido-engine.js';

    pdfjsLib.GlobalWorkerOptions.workerSrc = new URL('pdfjs-dist/build/pdf.worker.min.mjs', import.meta.url).href;

    const pdfCache = new Map<string, Promise<any>>();

    async function getPdf(url: string) {
      if (!pdfCache.has(url)) pdfCache.set(url, pdfjsLib.getDocument(url).promise);
      return pdfCache.get(url)!;
    }

    async function renderRegion(
      canvas: HTMLCanvasElement,
      region: { pdfUrl: string; page: number; x: number; y: number; w: number; h: number },
      scale: number
    ) {
      const pdf  = await getPdf(region.pdfUrl);
      const page = await pdf.getPage(region.page);
      const vp   = page.getViewport({ scale, offsetX: -region.x * scale, offsetY: -region.y * scale });
      canvas.width  = region.w * scale;
      canvas.height = region.h * scale;
      await page.render({ canvasContext: canvas.getContext('2d'), viewport: vp }).promise;
    }

    const overlay        = document.getElementById('gs-overlay')!;
    const overlayTitle   = document.getElementById('gs-overlay-title')!;
    const overlayCanvas  = document.getElementById('gs-overlay-canvas') as HTMLCanvasElement;
    const overlayLoading = document.getElementById('gs-overlay-loading')!;

    let lastRenderedKey: string | null = null;

    async function openGsOverlay(gsKey: string) {
      const gsPdfData: Record<string, any> = (window as any).__GS_PDF_DATA__ ?? {};
      const base: string = (window as any).__BASE_URL__ ?? '';
      const info = gsPdfData[gsKey];
      if (!info) return;

      overlay.classList.add('open');
      overlay.setAttribute('aria-hidden', 'false');
      overlayTitle.textContent = info.title ?? gsKey;

      if (lastRenderedKey === gsKey) return;
      lastRenderedKey = gsKey;

      overlayLoading.classList.remove('hidden');
      overlayCanvas.width = 0;
      overlayCanvas.height = 0;

      const dpr   = window.devicePixelRatio || 1;
      const maxW  = window.innerWidth * 0.85;
      const scale = (maxW / info.w) * dpr;

      await renderRegion(overlayCanvas, {
        pdfUrl: `${base}/pdf/guide-survie-c3.pdf`,
        page: info.page,
        x: info.x, y: info.y, w: info.w, h: info.h,
      }, scale);

      overlayCanvas.style.width  = Math.min(info.w * scale / dpr, maxW) + 'px';
      overlayCanvas.style.height = 'auto';
      overlayLoading.classList.add('hidden');
    }

    function closeGsOverlay() {
      overlay.classList.remove('open');
      overlay.setAttribute('aria-hidden', 'true');
      lastRenderedKey = null;
    }

    overlay.querySelectorAll('[data-close]').forEach(el => el.addEventListener('click', closeGsOverlay));
    overlay.addEventListener('click', e => { if (e.target === overlay) closeGsOverlay(); });
    document.addEventListener('keydown', e => { if (e.key === 'Escape') closeGsOverlay(); });

    const questions  = (window as any).__RAPIDO_QUESTIONS__ ?? [];
    const niveau     = (window as any).__RAPIDO_NIVEAU__ ?? '';
    const numero     = (window as any).__RAPIDO_NUMERO__ ?? '1';
    const grid       = document.getElementById('questions-grid')!;
    const pagination = document.getElementById('rapido-pagination');

    await initEngine(grid, questions, {
      prefix:         `${niveau}-${numero}-card`,
      pageSize:       6,
      paginationEl:   pagination,
      showEditor:     true,
      onGsBadgeClick: openGsOverlay,
    });
  </script>
</body>
</html>
