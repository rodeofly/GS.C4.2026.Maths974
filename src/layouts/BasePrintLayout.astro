---
import '../styles/main.css';
import Navbar from '../components/Navbar.astro';
import SubthemeInfo from '../components/SubthemeInfo.astro';

const { info, title, layoutClass, niveauLabel, indexContent, themeLabel } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const path = Astro.url.pathname;
const isRapido = path.includes('/rapidos/');
const rootLabel = isRapido ? 'Rapidos' : 'Guide';
const rootUrl = isRapido ? `${base}/rapidos/` : `${base}/guide/`;

const slug = info?.slug?.replace(/\/index$/, '') || '';
const niveauSlug = slug.split('/')[0];
---
<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <link rel="stylesheet" type="text/css" href="https://tikzjax.com/v1/fonts.css" />
    <script is:inline>
      window.MathJax = { tex: { inlineMath: [['$', '$'], ['\\(', '\\)']] }, svg: { fontCache: 'global' } };
    </script>
    <script src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-svg-full.js" defer></script>
    <script src="https://tikzjax.com/v1/tikzjax.js" defer></script>
  </head>
  <!-- PDF.js viewer — chargé une seule fois pour toutes les PdfEtiquette -->
  <script>
    import * as pdfjsLib from 'pdfjs-dist';
    pdfjsLib.GlobalWorkerOptions.workerSrc = new URL('pdfjs-dist/build/pdf.worker.min.mjs', import.meta.url).href;

    const pdfCache: Map<string, Promise<any>> = new Map();

    async function getPdf(url: string) {
      if (!pdfCache.has(url)) {
        pdfCache.set(url, pdfjsLib.getDocument(url).promise);
      }
      return pdfCache.get(url)!;
    }

    async function renderRegion(canvas: HTMLCanvasElement, region: { pdfUrl: string; page: number; x: number; y: number; w: number; h: number }, scale: number) {
      const pdf  = await getPdf(region.pdfUrl);
      const page = await pdf.getPage(region.page);
      const vp   = page.getViewport({ scale, offsetX: -region.x * scale, offsetY: -region.y * scale });
      canvas.width  = region.w * scale;
      canvas.height = region.h * scale;
      await page.render({ canvasContext: canvas.getContext('2d'), viewport: vp }).promise;
    }

    function initCard(wrap: HTMLElement) {
      const region = {
        pdfUrl: wrap.dataset.pdf!,
        page:   +wrap.dataset.page!,
        x:      +wrap.dataset.x!,
        y:      +wrap.dataset.y!,
        w:      +wrap.dataset.w!,
        h:      +wrap.dataset.h!,
      };

      const canvas  = wrap.querySelector<HTMLCanvasElement>('.pdf-canvas')!;
      const loading = wrap.querySelector<HTMLElement>('.pdf-loading')!;
      const lbId    = wrap.dataset.lightbox!;
      const lb      = document.getElementById(lbId)!;
      // Échapper à tout stacking context créé par les ancêtres (transform, etc.)
      document.body.appendChild(lb);
      const lbCanvas= lb.querySelector<HTMLCanvasElement>('.lb-canvas')!;

      const dpr = window.devicePixelRatio || 1;

      async function renderCard() {
        const sc = (wrap.clientWidth / region.w) * dpr;
        await renderRegion(canvas, region, sc);
        loading.classList.add('hidden');
      }

      const obs = new IntersectionObserver(entries => {
        if (entries[0].isIntersecting) {
          obs.disconnect();
          renderCard().catch(console.error);
        }
      }, { rootMargin: '400px' });
      obs.observe(wrap);

      let t: ReturnType<typeof setTimeout>;
      window.addEventListener('resize', () => { clearTimeout(t); t = setTimeout(renderCard, 250); });

      let lbRendered = false;
      async function openLb() {
        lb.classList.add('open');
        if (lbRendered) return;
        lbRendered = true;
        const sc = ((window.innerWidth * 0.9) / region.w) * dpr;
        lbCanvas.style.width  = Math.min(region.w * sc / dpr, window.innerWidth * 0.9) + 'px';
        lbCanvas.style.height = 'auto';
        await renderRegion(lbCanvas, region, sc);
      }

      function closeLb() {
        lb.classList.remove('open');
      }

      wrap.addEventListener('click', e => {
        if ((e.target as HTMLElement).closest('.isolate-btn')) return;
        openLb();
      });
      lb.querySelectorAll('[data-close]').forEach(el => el.addEventListener('click', closeLb));
      document.addEventListener('keydown', e => { if (e.key === 'Escape') closeLb(); });
    }

    document.querySelectorAll<HTMLElement>('.pdf-wrap').forEach(initCard);
  </script>
  <body class={`layout ${layoutClass}`}>
    <Navbar title={title} />
    
    <header class="layout-header-simple">
      <nav class="breadcrumb no-print" aria-label="Fil d'ariane">
        <ol>
          <li><a href={`${base}/`}>Accueil</a></li>
          {slug !== "" && slug !== "index" && (
            <>
              <li class="separator">/</li>
              <li><a href={rootUrl}>{rootLabel}</a></li>
            </>
          )}
          {niveauLabel && niveauSlug && slug !== niveauSlug && (
            <>
              <li class="separator">/</li>
              <li><a href={`${rootUrl}${niveauSlug}/`}>{niveauLabel}</a></li>
            </>
          )}
          <li class="separator">/</li>
          <li class="current" aria-current="page">
            {title}
            <SubthemeInfo info={info} Content={indexContent} />
          </li>
        </ol>
      </nav>
      <h1>{title}</h1>
    </header>

    <main class="etiquettes-grid">
      <slot />
    </main>

    <footer><slot name="footer" /></footer>
  </body>
</html>

<style>
/* ... Styles inchangés ... */
.layout-header-simple { display: flex; flex-direction: column; gap: var(--space-1); margin-bottom: var(--space-3); }
.breadcrumb ol { display: flex; flex-wrap: wrap; align-items: center; list-style: none; padding: 0; margin: 0; font-size: var(--text-sm); color: var(--color-gray-500); }
.breadcrumb a { color: var(--color-gray-600); text-decoration: none; transition: color 0.2s; }
.breadcrumb a:hover { color: var(--color-guide-primary); text-decoration: underline; }
.breadcrumb .separator { margin: 0 var(--space-2); color: var(--color-gray-400); font-size: 0.8em; }
.breadcrumb .current { font-weight: var(--font-bold); color: var(--color-gray-900); display: flex; align-items: center; }
.header-main h1 { margin: 0; font-size: clamp(var(--text-2xl), 4vw, var(--text-4xl)); font-weight: var(--font-black); color: var(--color-guide-primary); line-height: var(--leading-tight); }
@media print { .breadcrumb { display: none; } .layout-header-simple { margin-bottom: var(--space-4); } }
</style>